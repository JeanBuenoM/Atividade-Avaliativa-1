#include <stdio.h>

int main() {
    int m[3][3];

    printf("Digite os elementos da matriz:\n");
    for(int i = 0; i < 3; i++) {
        for(int j = 0; j < 3; j++) {
            scanf("%d", &m[i][j]);
        }
    }

    printf("Resultado:\n");
    for(int i = 0; i < 3; i++) {
        for(int j = 0; j < 3; j++) {
            printf("%d ", m[i][j] * 5);
        }
        printf("\n");
    }

    return 0;
}
