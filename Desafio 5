#include <stdio.h>

int main() {
    int v[3], m[3][3], resultado[3];

    printf("Digite o vetor:\n");
    for(int i = 0; i < 3; i++) {
        scanf("%d", &v[i]);
    }

    printf("Digite a matriz:\n");
    for(int i = 0; i < 3; i++) {
        for(int j = 0; j < 3; j++) {
            scanf("%d", &m[i][j]);
        }
    }

    for(int j = 0; j < 3; j++) {
        resultado[j] = 0;
        for(int i = 0; i < 3; i++) {
            resultado[j] += v[i] * m[i][j];
        }
    }

    printf("Resultado:\n");
    for(int i = 0; i < 3; i++) {
        printf("%d ", resultado[i]);
    }

    return 0;
}
