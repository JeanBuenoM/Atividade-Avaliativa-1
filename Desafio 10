#include <stdio.h>
#include <stdlib.h>

typedef struct {
    char nome[50];
    float nota;
} Aluno;

Aluno* maiorNota(Aluno *alunos, int n) {
    Aluno *maior = alunos;

    for(int i = 1; i < n; i++) {
        if((alunos + i)->nota > maior->nota) {
            maior = alunos + i;
        }
    }
    return maior;
}

int main() {
    int n;
    scanf("%d", &n);

    Aluno *alunos = (Aluno*) malloc(n * sizeof(Aluno));

    for(int i = 0; i < n; i++) {
        scanf("%s", (alunos + i)->nome);
        scanf("%f", &(alunos + i)->nota);
    }

    Aluno *top = maiorNota(alunos, n);

    printf("Maior nota: %s %.2f\n", top->nome, top->nota);

    free(alunos);
    return 0;
}
